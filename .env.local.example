# ==============================================================================
# Kahaania / Netflix Clone — Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
# ==============================================================================


# ------------------------------------------------------------------------------
# ASSET STORAGE (Cloudflare R2)
# ------------------------------------------------------------------------------
# Base URL for photos, audio, and cover images.
# Currently hardcoded in src/data/series.ts as ASSET_BASE_URL.
# To make it dynamic, change that constant to read from this env var.
#
# Where to get it:
#   1. Go to Cloudflare Dashboard → R2 → your bucket
#   2. Enable "Public access" on the bucket (Settings → Public access → Allow Access)
#   3. Copy the public bucket URL, e.g.: https://pub-abc123def456.r2.dev
#
# If using UploadThing instead:
#   - Set to "https://utfs.io/f" (or leave blank — UploadThing URLs are full URLs
#     and will be returned as-is by getPhotoUrl/getMusicUrl)
#
# ASSET_BASE_URL=https://pub-abc123def456.r2.dev


# ------------------------------------------------------------------------------
# MUX VIDEO — Signed Playback (Required for Signed policy videos)
# ------------------------------------------------------------------------------
# These enable JWT token signing for Mux videos with "Signed" playback policy.
# If omitted, the app falls back to unsigned (public) playback — videos with
# "Public" playback policy will still work without these.
#
# Where to get them:
#   1. Go to https://dashboard.mux.com
#   2. Navigate to Settings → Signing Keys
#   3. Click "Generate new key"
#   4. Mux will show you:
#      - Key ID → use as MUX_SIGNING_KEY
#      - Private Key (base64-encoded RSA private key) → use as MUX_PRIVATE_KEY
#   5. IMPORTANT: Save the private key immediately — Mux only shows it once!
#
# The private key is a long base64 string (starts with something like "LS0tLS1C...")
# Paste the entire string without line breaks.
#
MUX_SIGNING_KEY=your_signing_key_id
MUX_PRIVATE_KEY=your_base64_encoded_rsa_private_key


# ------------------------------------------------------------------------------
# MUX VIDEO — API Access (Optional, not currently used)
# ------------------------------------------------------------------------------
# These are for Mux API operations (uploading videos, managing assets, etc.)
# Not needed for playback — only needed if you add video management features.
#
# Where to get them:
#   1. Go to https://dashboard.mux.com
#   2. Navigate to Settings → API Access Tokens
#   3. Create a new token with "Mux Video" read/write permissions
#   4. Copy the Token ID and Token Secret
#
# MUX_TOKEN_ID=your_api_token_id
# MUX_TOKEN_SECRET=your_api_token_secret
